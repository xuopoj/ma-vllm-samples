#!/bin/sh
# TEMPLATE — multi-node rank dispatcher. Copy into a layout dir, drop ".tmpl",
# and fill the {{...}} placeholders. Run the SAME command on every node's
# ModelArts service; this script sources the spine, validates the rank table,
# and execs the right per-role launcher based on this node's rank.
#
#   sh /root/script/run.sh
#
# Placeholders:
#   {{NNODES}}        expected total node count (e.g. 2, 4)
#   {{GROUP0_SIZE}}   nodes ModelArts may route service traffic to — must be the
#                     ranks that actually run an API server (the leader, or the
#                     proxy host). Headless workers must NOT be in group 0.
#   {{RANK_CASES}}    one `N) exec "$here/run_<role>_nodeN.sh" ;;` per rank.

set -e

here=$(cd "$(dirname "$0")" && pwd)
. "$here/setup_rank_env.sh"   # exports AISHIPBOX_* + MASTER; waits for rank table

if [ "$AISHIPBOX_NNODES" != {{NNODES}} ]; then
    echo "[run] expected {{NNODES}} nodes, rank table has $AISHIPBOX_NNODES" >&2
    exit 1
fi
if [ "$AISHIPBOX_GROUP0_SIZE" != {{GROUP0_SIZE}} ]; then
    echo "[run] group 0 has $AISHIPBOX_GROUP0_SIZE nodes (want {{GROUP0_SIZE}})." >&2
    echo "[run] only group-0 ranks can serve ModelArts traffic; headless workers must be outside it." >&2
    exit 1
fi

case "$AISHIPBOX_NODE_RANK" in
    {{RANK_CASES}}
    *) echo "[run] unexpected AISHIPBOX_NODE_RANK=$AISHIPBOX_NODE_RANK" >&2; exit 1 ;;
esac
